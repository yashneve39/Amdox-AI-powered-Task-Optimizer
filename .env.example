# Environment Variables Template
# Copy this file to .env and fill in your values
# Contact: support@amdox.in

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=amdox_task_optimizer
DB_USER=amdox_user
DB_PASSWORD=your_secure_password_here

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
JWT_SECRET=your_jwt_secret_key_here
API_KEY=your_api_key_here

# Email Configuration (for notifications)
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_email_password_or_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Slack Integration (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# HR System Integration (optional)
HR_SYSTEM_API=https://your-hr-system.com/api
HR_SYSTEM_KEY=your_hr_system_api_key

# Model Configuration
HUGGINGFACE_TOKEN=your_huggingface_token_here

# Security
ENCRYPTION_KEY=your_32_byte_encryption_key_here
SALT=your_random_salt_here

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Feature Flags
ENABLE_WEBCAM=true
ENABLE_SPEECH=true
ENABLE_TEAM_ANALYTICS=true

# Development
DEBUG=false
LOG_LEVEL=INFO
ENVIRONMENT=development

# Privacy Settings
ANONYMIZE_DATA=true
DATA_RETENTION_DAYS=90
GDPR_MODE=true
